# =============================================================================
# NextICron Docs Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------

# Connection string used by Prisma Client at runtime (PrismaPg adapter).
DATABASE_URL="postgresql://user:password@localhost:5432/nexticron_docs"

# Connection string used by Prisma CLI for migrations (via prisma.config.ts).
# Can be the same as DATABASE_URL, or a direct connection if using a pooler above.
DIRECT_URL="postgresql://user:password@localhost:5432/nexticron_docs"

# -----------------------------------------------------------------------------
# Redis (user session cache)
# -----------------------------------------------------------------------------

# Connection string for Redis (used to cache LDAP groups/admin status for SSR).
REDIS_URL="redis://localhost:6379"

# -----------------------------------------------------------------------------
# JWT Session
# -----------------------------------------------------------------------------

# Secret key for signing session JWTs. Must be at least 32 characters.
JWT_SECRET="change-me-to-a-random-string-at-least-32-chars"

# Access token lifetime in minutes (default: 15).
ACCESS_TOKEN_EXPIRY_MINS=15

# Refresh token and session cookie (SSR identity) lifetime in days (default: 7).
REFRESH_AND_SESSION_TOKEN_EXPIRY_DAYS=7

# -----------------------------------------------------------------------------
# LDAP / FreeIPA Directory
# -----------------------------------------------------------------------------

# LDAP server URL (use ldaps:// for TLS).
LDAP_URL="ldaps://ipa.example.test:636"

# Base DN used to resolve user/group entries.
LDAP_BASE_DN="dc=example,dc=test"

# Template used to build the user DN for bind operations.
# Must contain {username} placeholder.
LDAP_USER_DN_TEMPLATE="uid={username},cn=users,cn=accounts,dc=example,dc=test"

# Optional LDAP attribute overrides.
LDAP_GROUP_ATTRIBUTE="memberOf"
LDAP_UID_ATTRIBUTE="uid"
LDAP_DISPLAY_NAME_ATTRIBUTE="cn"
LDAP_EMAIL_ATTRIBUTE="mail"

# Optional: set true only for development with self-signed certificates.
LDAP_ALLOW_INSECURE_TLS=true

# Service account DN and password for LDAP read-only lookups (used during
# refresh token flow to re-query user groups without the user's password).
LDAP_SERVICE_BIND_DN="uid=svc-docs,cn=users,cn=accounts,dc=example,dc=test"
LDAP_SERVICE_BIND_PASSWORD="change-me"

# Global docs admin group (distinct from default FreeIPA admins group).
FREEIPA_DOCS_ADMIN_GROUP="docs-admins"
